#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${PLUGIN_ROOT}/skills/using-workflow-kit/SKILL.md"
REGISTRY_FILE="${PLUGIN_ROOT}/.codex/workflows/registry.toml"

skill_content="$(cat "$SKILL_FILE" 2>/dev/null || echo "using-workflow-kit skill not found")"
registry_summary="Workflow registry: .codex/workflows/registry.toml"
if [ -f "$REGISTRY_FILE" ] && ! grep -q '^\[workflow\.' "$REGISTRY_FILE"; then
  registry_summary="Workflow registry is present and currently has no concrete workflows."
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="<WORKFLOW_KIT_BOOTSTRAP>\nYou have codex-workflow-kit. Use the using-workflow-kit skill before selecting workflow or fallback skills.\n\n${registry_summary}\n\n${skill_content}\n</WORKFLOW_KIT_BOOTSTRAP>"
escaped="$(escape_for_json "$context")"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
fi
