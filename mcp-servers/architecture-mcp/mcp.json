{
  "name": "architecture-mcp",
  "version": "1.0.0",
  "tools": [
    {
      "name": "architecture.generate_system_design",
      "title": "Generate system design",
      "description": "Generate bounded components, data flows, trade-offs, and validation questions.",
      "inputSchema": {
        "type": "object", "additionalProperties": false,
        "required": ["systemGoal", "qualityAttributes"],
        "properties": {
          "systemGoal": { "type": "string", "minLength": 1 },
          "qualityAttributes": { "type": "string", "minLength": 1 },
          "constraints": { "type": "array", "items": { "type": "string" } }
        }
      },
      "outputSchema": { "type": "object", "required": ["components", "dataFlows", "tradeoffs", "validationQuestions"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false }
    },
    {
      "name": "architecture.review_architecture",
      "title": "Review architecture",
      "description": "Review architecture boundaries, risks, recommendations, and unresolved decisions.",
      "inputSchema": {
        "type": "object", "additionalProperties": false,
        "required": ["architectureSummary", "reviewFocus"],
        "properties": {
          "architectureSummary": { "type": "string", "minLength": 1 },
          "reviewFocus": { "type": "string", "minLength": 1 },
          "constraints": { "type": "array", "items": { "type": "string" } }
        }
      },
      "outputSchema": { "type": "object", "required": ["findings", "risks", "recommendations", "decisionQuestions"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false }
    },
    {
      "name": "architecture.generate_adr",
      "title": "Generate architecture decision record",
      "description": "Generate a traceable architecture decision with consequences and alternatives.",
      "inputSchema": {
        "type": "object", "additionalProperties": false,
        "required": ["decisionTitle", "context", "options"],
        "properties": {
          "decisionTitle": { "type": "string", "minLength": 1 },
          "context": { "type": "string", "minLength": 1 },
          "options": { "type": "string", "minLength": 1 },
          "constraints": { "type": "array", "items": { "type": "string" } }
        }
      },
      "outputSchema": { "type": "object", "required": ["status", "decision", "consequences", "alternatives"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false }
    }
  ]
}
