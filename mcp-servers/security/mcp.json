{
  "name": "security",
  "version": "1.0.0",
  "tools": [
    {
      "name": "security.scan_source",
      "title": "Review source security",
      "description": "Review source-level findings, severity, remediation, and verification.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceSummary",
          "threatContext"
        ],
        "properties": {
          "sourceSummary": {
            "type": "string",
            "minLength": 1
          },
          "threatContext": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "findings",
          "severitySummary",
          "remediations",
          "verification"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "security.scan_dependencies",
      "title": "Review dependency security",
      "description": "Review dependency findings, upgrade actions, supply-chain checks, and verification.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dependencyManifest",
          "runtimeContext"
        ],
        "properties": {
          "dependencyManifest": {
            "type": "string",
            "minLength": 1
          },
          "runtimeContext": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "findings",
          "upgradeActions",
          "supplyChainChecks",
          "verification"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "security.generate_threat_model",
      "title": "Generate threat model",
      "description": "Generate assets, threats, mitigations, and validation questions for trust boundaries.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "systemSummary",
          "trustBoundaries"
        ],
        "properties": {
          "systemSummary": {
            "type": "string",
            "minLength": 1
          },
          "trustBoundaries": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "assets",
          "threats",
          "mitigations",
          "validationQuestions"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    }
  ]
}
