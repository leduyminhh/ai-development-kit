{
  "name": "data",
  "version": "1.0.0",
  "tools": [
    {
      "name": "data.analyze_schema",
      "title": "Analyze data schema",
      "description": "Analyze schema integrity, normalization, query risks, and recommendations.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaSummary",
          "workloadProfile"
        ],
        "properties": {
          "schemaSummary": {
            "type": "string",
            "minLength": 1
          },
          "workloadProfile": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "findings",
          "normalizationNotes",
          "queryRisks",
          "recommendations"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "data.review_index",
      "title": "Review database indexes",
      "description": "Review candidate indexes, trade-offs, and verification queries.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tableAndQueries",
          "performanceGoal"
        ],
        "properties": {
          "tableAndQueries": {
            "type": "string",
            "minLength": 1
          },
          "performanceGoal": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "findings",
          "candidateIndexes",
          "tradeoffs",
          "verificationQueries"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "data.migration_plan",
      "title": "Create data migration plan",
      "description": "Create reversible migration stages, data checks, rollback, and cutover gates.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceContract",
          "targetContract"
        ],
        "properties": {
          "sourceContract": {
            "type": "string",
            "minLength": 1
          },
          "targetContract": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "stages",
          "dataChecks",
          "rollbackPlan",
          "cutoverGates"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    }
  ]
}
