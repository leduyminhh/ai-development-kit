{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiep.dev/schemas/plugin-artifact.schema.json",
  "title": "AIEP Plugin Artifact",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "compatibility", "dependencies", "assets"],
  "properties": {
    "apiVersion": { "const": "aiep.dev/v1alpha1" },
    "kind": { "const": "PluginArtifact" },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "version", "description"]
    },
    "compatibility": { "type": "object" },
    "dependencies": { "type": "object" },
    "assets": { "type": "object" }
  },
  "additionalProperties": false
}
