{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidk.dev/schemas/package.schema.json",
  "title": "AIDK Package",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "compatibility", "dependencies", "assets", "install"],
  "properties": {
    "apiVersion": {
      "const": "aidk.dev/v1alpha1"
    },
    "kind": {
      "const": "Package"
    },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "version", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "required": ["aidk", "providers"],
      "properties": {
        "aidk": {
          "type": "string"
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "enum": ["supported", "planned", "unsupported"]
          }
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "required": ["skills", "agents", "workflows", "hooks"],
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "workflows": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "install": {
      "type": "object",
      "required": ["defaultScope", "supportsCopy", "supportsLink"],
      "properties": {
        "defaultScope": {
          "enum": ["project", "global"]
        },
        "supportsCopy": {
          "type": "boolean"
        },
        "supportsLink": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
