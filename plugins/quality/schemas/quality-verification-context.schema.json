{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-engineering.dev/schemas/quality/quality-verification-context.schema.json",
  "title": "Quality Verification Context",
  "type": "object",
  "required": [
    "changeScope",
    "acceptanceCriteria",
    "scenarioSummary",
    "executedTests"
  ],
  "properties": {
    "changeScope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scenarioSummary": { "type": "string", "minLength": 1 },
    "executedTests": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "failures": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "residualRisks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
