{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-engineering.dev/schemas/architecture/architecture-review-context.schema.json",
  "title": "Architecture Review Context",
  "type": "object",
  "required": [
    "sourceScope",
    "summary",
    "criticalFindings",
    "recommendedVerification"
  ],
  "properties": {
    "sourceScope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "architectureConstraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "summary": { "type": "string", "minLength": 1 },
    "criticalFindings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "boundaryFindings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommendedVerification": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
