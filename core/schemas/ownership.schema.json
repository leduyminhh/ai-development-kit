{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-engineering.dev/schemas/ownership.schema.json",
  "title": "AI Engineering Managed File Ownership",
  "type": "object",
  "required": ["schemaVersion", "files"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["owners", "assetType", "assetId", "checksum", "shared"]
      }
    }
  },
  "additionalProperties": false
}
