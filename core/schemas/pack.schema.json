{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-engineering.dev/schemas/pack.schema.json",
  "title": "AI Engineering Capability Pack",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "id",
    "name",
    "version",
    "description",
    "category",
    "triggers",
    "commands",
    "skills",
    "depends_on"
  ],
  "properties": {
    "apiVersion": {
      "const": "ai-engineering.dev/v1alpha1"
    },
    "kind": {
      "const": "CapabilityPack"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "const": "capability-pack"
    },
    "triggers": {
      "type": "object",
      "required": ["keywords"],
      "properties": {
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "file", "mcp_tool"]
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path"]
      }
    },
    "depends_on": {
      "type": "object"
    }
  }
}
